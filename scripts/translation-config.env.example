# AI 提示词自动翻译配置文件
# 复制此文件为 translation-config.env 并填入您的 API Key

# 选择翻译提供者：openrouter | anthropic
TRANSLATION_PROVIDER=openrouter

# --- OpenRouter 配置（推荐） ---
OPENROUTER_API_KEY=your_openrouter_key_here
# 若使用自建网关，可改为专属地址
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# 默认模型：Anthropic Claude Opus 4.6
OPENROUTER_MODEL=anthropic/claude-opus-4.6
OPENROUTER_MAX_TOKENS=12000
# 大文件/分块时的模型与长度
OPENROUTER_LARGE_MODEL=anthropic/claude-opus-4.6
OPENROUTER_LARGE_MAX_TOKENS=20000

# --- Anthropic 备用配置 ---
# ANTHROPIC_API_KEY=your_anthropic_key
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# 通用默认值（脚本内部会按需覆盖）
MODEL=anthropic/claude-opus-4.6
MAX_TOKENS=12000
